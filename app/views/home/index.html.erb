    <p class="text-lg text-medium italic">Tu camino hacia un descanso más pleno</p>
  </div>

  <div class="flex flex-col sm:flex-row gap-6 w-full max-w-xl">
    <a href="/cuestionario"
       class="flex-1 bg-warm-white border-2 border-cream rounded-2xl p-8 text-center shadow-md hover:shadow-xl hover:-translate-y-1 transition-all">
