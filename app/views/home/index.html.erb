    <a href="/diario"
       class="flex-1 bg-warm-white border-2 border-cream rounded-2xl p-8 text-center shadow-md hover:shadow-xl hover:-translate-y-1 transition-all">
      <div class="text-4xl mb-4">📓</div>
      <h2 class="text-2xl font-bold text-green mb-2">Diario</h2>
